<UserControl x:Class="PDV.WPF.Controls.PaymentPieChart"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Width="190" Height="190">
            <Canvas x:Name="ChartCanvas" Width="190" Height="190"/>
            <TextBlock x:Name="EmptyLabel"
                       Text="Sem dados"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Opacity="0.5" Visibility="Collapsed"/>
        </Grid>

        <ItemsControl x:Name="Legend" Grid.Column="1"
                      Margin="20,0,0,0" VerticalAlignment="Center">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="14" Height="14" CornerRadius="3"
                                Background="{Binding Brush}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding Label}"
                                   Margin="8,0,12,0" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" VerticalAlignment="Center" FontWeight="SemiBold">
                            <Run Text="{Binding ValueText, Mode=OneWay}"/>
                            <Run Text="{Binding PercentText, Mode=OneWay}" Foreground="Gray"/>
                        </TextBlock>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>
