<Window x:Class="PDV.WPF.Views.ProductEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:conv="clr-namespace:PDV.WPF.Converters"
        Title="{Binding DialogTitle}"
        Height="620" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Style="{StaticResource MaterialDesignWindow}"
        Loaded="Window_Loaded"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <conv:BoolToVisibilityConverter        x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
        <conv:EmptyStringToVisibilityConverter x:Key="StrToVis"/>
        <conv:CurrencyConverter                x:Key="Currency"/>
        <conv:DecimalInputConverter            x:Key="DecimalInput"/>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,20,28,24">

            <!-- Title -->
            <TextBlock Text="{Binding DialogTitle}"
                       FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

            <!-- ── Seção: Identificação ── -->
            <TextBlock Text="IDENTIFICAÇÃO" FontSize="10" FontWeight="Bold"
                       Opacity="0.5" Margin="0,0,0,8"/>

            <TextBox x:Name="TxtName"
                     materialDesign:HintAssist.Hint="Nome do Produto *"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,10"/>

            <TextBox materialDesign:HintAssist.Hint="Descrição"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,10"/>

            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         materialDesign:HintAssist.Hint="Código de Barras (EAN)"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding Barcode, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBox Grid.Column="2"
                         materialDesign:HintAssist.Hint="Código Interno"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding InternalCode, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>

            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0"
                          materialDesign:HintAssist.Hint="Categoria"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          ItemsSource="{Binding Categories}"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Id"
                          SelectedValue="{Binding CategoryId}"/>
                <ComboBox Grid.Column="2"
                          materialDesign:HintAssist.Hint="Fornecedor"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          ItemsSource="{Binding Suppliers}"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Id"
                          SelectedValue="{Binding SupplierId}"/>
            </Grid>

            <ComboBox materialDesign:HintAssist.Hint="Unidade de Medida"
                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                      ItemsSource="{Binding Units}"
                      SelectedItem="{Binding UnitOfMeasure}"
                      Margin="0,0,0,16"/>

            <!-- ── Seção: Preços ── -->
            <TextBlock Text="PREÇOS" FontSize="10" FontWeight="Bold"
                       Opacity="0.5" Margin="0,0,0,8"/>

            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <!-- Preço de custo só visível para Admin -->
                <TextBox Grid.Column="0"
                         materialDesign:HintAssist.Hint="Preço de Custo (R$)"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding CostPrice,
                                Converter={StaticResource DecimalInput},
                                UpdateSourceTrigger=LostFocus}"
                         Visibility="{Binding CanEditCost, Converter={StaticResource BoolToVis}}"/>
                <TextBox Grid.Column="2"
                         materialDesign:HintAssist.Hint="Preço de Venda (R$) *"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding SalePrice,
                                Converter={StaticResource DecimalInput},
                                UpdateSourceTrigger=LostFocus}"/>
            </Grid>

            <!-- Margem calculada (Admin only) -->
            <Border Background="{DynamicResource MaterialDesign.Brush.Primary}"
                    CornerRadius="6" Padding="12,8" Margin="0,0,0,16"
                    Visibility="{Binding CanEditCost, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <materialDesign:PackIcon Kind="TrendingUp" Width="18" Height="18"
                                             Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Foreground="White" VerticalAlignment="Center">
                        <Run Text="Markup: "/>
                        <Run Text="{Binding Margin, StringFormat=N1, Mode=OneWay}"/>
                        <Run Text="%  |  Lucro: "/>
                        <Run Text="{Binding Profit, StringFormat=C2, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- ── Seção: Estoque ── -->
            <TextBlock Text="ESTOQUE" FontSize="10" FontWeight="Bold"
                       Opacity="0.5" Margin="0,0,0,8"/>

            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         materialDesign:HintAssist.Hint="Qtd. em Estoque"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding StockQuantity,
                                Converter={StaticResource DecimalInput},
                                UpdateSourceTrigger=LostFocus}"/>
                <TextBox Grid.Column="2"
                         materialDesign:HintAssist.Hint="Qtd. Mínima (alerta)"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding MinStockQuantity,
                                Converter={StaticResource DecimalInput},
                                UpdateSourceTrigger=LostFocus}"/>
            </Grid>

            <!-- Error -->
            <Border Background="#FFFFE0E0" CornerRadius="4" Padding="10,6"
                    Margin="0,0,0,8"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource StrToVis}}">
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#FFC62828" FontWeight="SemiBold" TextWrapping="Wrap"/>
            </Border>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
                <Button Content="Cancelar"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Command="{Binding CancelCommand}"
                        Width="100" Margin="0,0,10,0"/>
                <Button Content="Salvar"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Command="{Binding SaveCommand}"
                        IsDefault="True" Width="100"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Window>
