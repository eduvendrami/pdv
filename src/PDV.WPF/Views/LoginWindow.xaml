<Window x:Class="PDV.WPF.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="PDV - Material de Construção"
        Height="450" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Style="{StaticResource MaterialDesignWindow}">
    <Grid Background="{DynamicResource MaterialDesign.Brush.Primary}">
        <materialDesign:Card Margin="32" Padding="32" VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="PDV" FontSize="36" FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
                <TextBlock Text="Material de Construção" FontSize="14"
                           HorizontalAlignment="Center" Margin="0,0,0,24"
                           Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}"/>

                <TextBox x:Name="TxtUsername"
                         materialDesign:HintAssist.Hint="Usuário"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,8"
                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>

                <PasswordBox x:Name="PwdPassword"
                             materialDesign:HintAssist.Hint="Senha"
                             Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                             Margin="0,8"/>

                <TextBlock Text="{Binding ErrorMessage}" Foreground="Red"
                           Margin="0,4" TextWrapping="Wrap"
                           />

                <Button Content="ENTRAR"
                        Margin="0,16,0,0"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        IsDefault="True"
                        Command="{Binding LoginCommand}"
                        CommandParameter="{Binding ElementName=PwdPassword}"/>
            </StackPanel>
        </materialDesign:Card>
    </Grid>
</Window>
