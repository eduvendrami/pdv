<UserControl x:Class="PDV.WPF.Views.NFeImportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:conv="clr-namespace:PDV.WPF.Converters">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter        x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
        <conv:EmptyStringToVisibilityConverter x:Key="StrToVis"/>
        <conv:BoolToStringConverter            x:Key="BoolToStr"/>
    </UserControl.Resources>

    <DockPanel Margin="20,16,20,16">

        <!-- ══ Header ══ -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <materialDesign:PackIcon Kind="FileDocumentOutline"
                                         Width="28" Height="28"
                                         Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                                         VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="Importação de NF-e"
                           FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <!-- Botão Novo arquivo (quando já importou) -->
                <Button Content="Novo arquivo"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Command="{Binding ResetCommand}"
                        Margin="0,0,10,0"
                        Visibility="{Binding ImportDone, Converter={StaticResource BoolToVis}}"/>

                <Button Style="{StaticResource MaterialDesignRaisedButton}"
                        Command="{Binding SelectFileCommand}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FolderOpen" Width="18" Height="18"
                                                 VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Selecionar XML" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ══ Placeholder (nenhum arquivo) ══ -->
        <Border DockPanel.Dock="Top"
                Visibility="{Binding FileLoaded, Converter={StaticResource InvBoolToVis}}"
                Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                CornerRadius="12" Padding="40"
                materialDesign:ElevationAssist.Elevation="Dp1">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <materialDesign:PackIcon Kind="FileXmlBox"
                                         Width="64" Height="64"
                                         HorizontalAlignment="Center"
                                         Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                                         Opacity="0.4"/>
                <TextBlock Text="Nenhum arquivo selecionado"
                           FontSize="16" FontWeight="SemiBold"
                           HorizontalAlignment="Center" Margin="0,16,0,6"
                           Opacity="0.6"/>
                <TextBlock Text="Clique em &quot;Selecionar XML&quot; para carregar uma NF-e"
                           HorizontalAlignment="Center" Opacity="0.4"/>
                <Border Background="#FFFFE0E0" CornerRadius="6" Padding="12,8"
                        Margin="0,16,0,0"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource StrToVis}}">
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="#FFC62828" FontWeight="SemiBold" TextWrapping="Wrap"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- ══ Conteúdo (arquivo carregado) ══ -->
        <ScrollViewer DockPanel.Dock="Top"
                      VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding FileLoaded, Converter={StaticResource BoolToVis}}">
            <StackPanel>

                <!-- ── Cards de informação ── -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Card NF-e -->
                    <Border Grid.Column="0"
                            Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                            CornerRadius="8" Padding="16"
                            materialDesign:ElevationAssist.Elevation="Dp1">
                        <StackPanel>
                            <TextBlock Text="DADOS DA NOTA" FontSize="10" FontWeight="Bold"
                                       Opacity="0.5" Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Nº NF-e:" FontWeight="SemiBold" Margin="0,0,12,4"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding NfeInfo.NfeNumber}"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Emissão:"  FontWeight="SemiBold" Margin="0,0,12,4"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding NfeInfo.EmissionDate, StringFormat=dd/MM/yyyy HH:mm}"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Total:"    FontWeight="SemiBold" Margin="0,0,12,0"/>
                                <TextBlock Grid.Row="2" Grid.Column="1"
                                           Text="{Binding NfeInfo.TotalValue, StringFormat=C2}"
                                           FontSize="16" FontWeight="Bold"
                                           Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Card Fornecedor -->
                    <Border Grid.Column="2"
                            Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                            CornerRadius="8" Padding="16"
                            materialDesign:ElevationAssist.Elevation="Dp1">
                        <StackPanel>
                            <TextBlock Text="FORNECEDOR" FontSize="10" FontWeight="Bold"
                                       Opacity="0.5" Margin="0,0,0,10"/>
                            <TextBlock Text="{Binding NfeInfo.Supplier.Name}"
                                       FontWeight="Bold" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding NfeInfo.Supplier.TradeName}"
                                       Opacity="0.6" FontSize="12"/>
                            <TextBlock Text="{Binding NfeInfo.Supplier.Cnpj}"
                                       FontSize="12" Margin="0,4,0,4"/>

                            <!-- Status do fornecedor -->
                            <Border CornerRadius="10" Padding="8,3" HorizontalAlignment="Left" Margin="0,4,0,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#E8F5E9"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SupplierIsNew}" Value="False">
                                                <Setter Property="Background" Value="#E3F2FD"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding SupplierStatus}" FontSize="11" FontWeight="SemiBold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#388E3C"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SupplierIsNew}" Value="False">
                                                    <Setter Property="Foreground" Value="#1565C0"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ── Opções de importação ── -->
                <Border Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                        CornerRadius="8" Padding="16,12" Margin="0,0,0,12"
                        materialDesign:ElevationAssist.Elevation="Dp1">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Tune" Width="18" Height="18"
                                                 VerticalAlignment="Center" Margin="0,0,12,0"
                                                 Opacity="0.6"/>
                        <TextBlock Text="Markup padrão:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox materialDesign:HintAssist.Hint="%"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Width="80" Height="36"
                                 Text="{Binding DefaultMarkup, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="%" VerticalAlignment="Center" Margin="4,0,24,0" Opacity="0.6"/>

                        <CheckBox IsChecked="{Binding AddToStock}"
                                  VerticalAlignment="Center">
                            <TextBlock Text="Adicionar quantidades ao estoque"/>
                        </CheckBox>

                        <!-- Resumo -->
                        <StackPanel Orientation="Horizontal" Margin="24,0,0,0" VerticalAlignment="Center">
                            <Border Background="#E8F5E9" CornerRadius="10" Padding="8,2" Margin="0,0,6,0">
                                <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#388E3C">
                                    <Run Text="{Binding TotalNew, Mode=OneWay}"/>
                                    <Run Text=" novos"/>
                                </TextBlock>
                            </Border>
                            <Border Background="#E3F2FD" CornerRadius="10" Padding="8,2">
                                <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#1565C0">
                                    <Run Text="{Binding TotalExisting, Mode=OneWay}"/>
                                    <Run Text=" existentes"/>
                                </TextBlock>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ── Grade de produtos ── -->
                <TextBlock Text="PRODUTOS DA NOTA" FontSize="10" FontWeight="Bold"
                           Opacity="0.5" Margin="0,0,0,8"/>

                <DataGrid ItemsSource="{Binding Items}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="False"
                          Style="{StaticResource MaterialDesignDataGrid}"
                          materialDesign:DataGridAssist.CellPadding="8,5"
                          Margin="0,0,0,16">
                    <DataGrid.Columns>

                        <!-- Importar checkbox -->
                        <DataGridTemplateColumn Header="Imp." Width="50">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding Import, UpdateSourceTrigger=PropertyChanged}"
                                              HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Status chip -->
                        <DataGridTemplateColumn Header="Status" Width="90" SortMemberPath="Status">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="10" Padding="6,2" HorizontalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#E8F5E9"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsExisting}" Value="True">
                                                        <Setter Property="Background" Value="#E3F2FD"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Status}" FontSize="10" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#388E3C"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsExisting}" Value="True">
                                                            <Setter Property="Foreground" Value="#1565C0"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Código"  Binding="{Binding InternalCode}" Width="75"/>
                        <DataGridTextColumn Header="Barcode" Binding="{Binding Barcode}"      Width="115"/>
                        <DataGridTextColumn Header="Nome"    Binding="{Binding Name}"         Width="*"/>
                        <DataGridTextColumn Header="Un."     Binding="{Binding UnitLabel}"    Width="45"/>
                        <DataGridTextColumn Header="Qtd"
                                            Binding="{Binding Quantity, StringFormat=N2}"     Width="60"/>
                        <DataGridTextColumn Header="Custo (R$)"
                                            Binding="{Binding CostPrice, StringFormat=C2}"   Width="90"/>

                        <!-- Preço de venda (editável) -->
                        <DataGridTemplateColumn Header="Venda (R$)" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding SalePrice, StringFormat=C2}"
                                               VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding SalePrice, UpdateSourceTrigger=PropertyChanged}"
                                             materialDesign:HintAssist.Hint="R$"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>

                    <!-- Linha existente = azul claro -->
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow" BasedOn="{StaticResource MaterialDesignDataGridRow}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsExisting}" Value="True">
                                    <Setter Property="Background" Value="#F3F8FF"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                </DataGrid>

                <!-- ── Mensagens ── -->
                <Border Background="#FFFFE0E0" CornerRadius="6" Padding="12,8"
                        Margin="0,0,0,12"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource StrToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AlertCircle" Width="18" Height="18"
                                                 Foreground="#FFC62828" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="#FFC62828" FontWeight="SemiBold" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Background="#FFE8F5E9" CornerRadius="6" Padding="12,10"
                        Margin="0,0,0,12"
                        Visibility="{Binding ResultMessage, Converter={StaticResource StrToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CheckCircle" Width="20" Height="20"
                                                 Foreground="#FF388E3C" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="{Binding ResultMessage}"
                                   Foreground="#FF2E7D32" FontWeight="SemiBold"
                                   VerticalAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- ── Botão importar ── -->
                <Button HorizontalAlignment="Right"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Command="{Binding ImportCommand}"
                        Height="44" Width="200" FontSize="14"
                        Visibility="{Binding ImportDone, Converter={StaticResource InvBoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="DatabaseImport" Width="20" Height="20"
                                                 VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Importar" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>
</UserControl>
