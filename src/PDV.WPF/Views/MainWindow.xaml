<Window x:Class="PDV.WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:PDV.WPF.ViewModels"
        xmlns:v="clr-namespace:PDV.WPF.Views"
        xmlns:conv="clr-namespace:PDV.WPF.Converters"
        Title="PDV - Material de Construção"
        Height="768" Width="1280"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource MaterialDesignWindow}">
    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <DataTemplate DataType="{x:Type vm:SaleViewModel}">
            <v:SaleView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProductListViewModel}">
            <v:ProductListView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CustomerListViewModel}">
            <v:CustomerListView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SupplierListViewModel}">
            <v:SupplierListView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:StockViewModel}">
            <v:StockView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CashViewModel}">
            <v:CashView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReportsViewModel}">
            <v:ReportsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:UserListViewModel}">
            <v:UserListView/>
        </DataTemplate>
    </Window.Resources>

    <DockPanel>

        <!-- ══ Top bar ══ -->
        <materialDesign:ColorZone Mode="PrimaryMid" DockPanel.Dock="Top" Padding="8,4">
            <DockPanel>
                <ToggleButton Style="{StaticResource MaterialDesignHamburgerToggleButton}"
                              IsChecked="{Binding IsMenuOpen}"
                              DockPanel.Dock="Left"/>

                <TextBlock Text="PDV - Material de Construção"
                           VerticalAlignment="Center" FontSize="16" Margin="16,0"/>

                <!-- User info + role badge (right side) -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="16,0">
                    <Border CornerRadius="10" Padding="8,2" Margin="0,0,10,0"
                            Background="#33FFFFFF">
                        <TextBlock Text="{Binding CurrentUserRole}"
                                   FontSize="11" FontWeight="Bold" Foreground="White"/>
                    </Border>
                    <materialDesign:PackIcon Kind="AccountCircleOutline"
                                             Width="18" Height="18" VerticalAlignment="Center"
                                             Foreground="White" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding CurrentUserName}"
                               VerticalAlignment="Center" Foreground="White"/>
                </StackPanel>
            </DockPanel>
        </materialDesign:ColorZone>

        <!-- ══ Body: sidebar + content ══ -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarColumn" Width="0"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── Sidebar nav ── -->
            <Border Grid.Column="0"
                    Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                    BorderBrush="{DynamicResource MaterialDesign.Brush.Primary}"
                    BorderThickness="0,0,1,0"
                    ClipToBounds="True">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Width="240" Margin="0,12">

                        <!-- ── All roles ── -->
                        <TextBlock Text="VENDAS" FontSize="10" FontWeight="Bold"
                                   Margin="16,4,0,4" Opacity="0.5"/>

                        <Button Style="{StaticResource MaterialDesignFlatButton}"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                Padding="16,10" Command="{Binding NavigateToSaleCommand}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CartOutline" Width="20" Height="20" VerticalAlignment="Center"/>
                                <TextBlock Text="Vendas (F2)" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- ── Gerente+ ── -->
                        <StackPanel Visibility="{Binding ShowManagement, Converter={StaticResource BoolToVis}}">
                            <Separator Margin="16,6"/>
                            <TextBlock Text="GESTÃO" FontSize="10" FontWeight="Bold"
                                       Margin="16,4,0,4" Opacity="0.5"/>

                            <Button Style="{StaticResource MaterialDesignFlatButton}"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                    Padding="16,10" Command="{Binding NavigateToProductsCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="PackageVariantClosed" Width="20" Height="20" VerticalAlignment="Center"/>
                                    <TextBlock Text="Produtos" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource MaterialDesignFlatButton}"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                    Padding="16,10" Command="{Binding NavigateToCustomersCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="AccountGroupOutline" Width="20" Height="20" VerticalAlignment="Center"/>
                                    <TextBlock Text="Clientes" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource MaterialDesignFlatButton}"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                    Padding="16,10" Command="{Binding NavigateToSuppliersCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="TruckOutline" Width="20" Height="20" VerticalAlignment="Center"/>
                                    <TextBlock Text="Fornecedores" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource MaterialDesignFlatButton}"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                    Padding="16,10" Command="{Binding NavigateToStockCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ChartBoxOutline" Width="20" Height="20" VerticalAlignment="Center"/>
                                    <TextBlock Text="Estoque" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource MaterialDesignFlatButton}"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                    Padding="16,10" Command="{Binding NavigateToCashCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="CashRegister" Width="20" Height="20" VerticalAlignment="Center"/>
                                    <TextBlock Text="Caixa" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource MaterialDesignFlatButton}"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                    Padding="16,10" Command="{Binding NavigateToReportsCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="FileChartOutline" Width="20" Height="20" VerticalAlignment="Center"/>
                                    <TextBlock Text="Relatórios" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- ── Admin only ── -->
                        <StackPanel Visibility="{Binding ShowUsers, Converter={StaticResource BoolToVis}}">
                            <Separator Margin="16,6"/>
                            <TextBlock Text="ADMINISTRAÇÃO" FontSize="10" FontWeight="Bold"
                                       Margin="16,4,0,4" Opacity="0.5"/>

                            <Button Style="{StaticResource MaterialDesignFlatButton}"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                    Padding="16,10" Command="{Binding NavigateToUsersCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="AccountCogOutline" Width="20" Height="20" VerticalAlignment="Center"/>
                                    <TextBlock Text="Usuários" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- ── Always visible ── -->
                        <Separator Margin="16,6"/>

                        <!-- Verificar atualizações -->
                        <Button Style="{StaticResource MaterialDesignFlatButton}"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                Padding="16,10" Command="{Binding CheckUpdatesCommand}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CloudDownloadOutline" Width="20" Height="20"
                                                         VerticalAlignment="Center"
                                                         Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
                                <TextBlock Text="Verificar atualizações" Margin="12,0,0,0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource MaterialDesignFlatButton}"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                Padding="16,10" Command="{Binding LogoutCommand}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="LogoutVariant" Width="20" Height="20"
                                                         VerticalAlignment="Center"
                                                         Foreground="{DynamicResource MaterialDesign.Brush.Secondary}"/>
                                <TextBlock Text="Sair" Margin="12,0,0,0" VerticalAlignment="Center"
                                           Foreground="{DynamicResource MaterialDesign.Brush.Secondary}"/>
                            </StackPanel>
                        </Button>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ── Page content ── -->
            <ContentControl Grid.Column="1" Content="{Binding CurrentView}"/>
        </Grid>
    </DockPanel>
</Window>
