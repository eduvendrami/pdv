<Window x:Class="PDV.WPF.Views.UserEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:conv="clr-namespace:PDV.WPF.Converters"
        Title="{Binding DialogTitle}"
        Height="460" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Style="{StaticResource MaterialDesignWindow}"
        Loaded="Window_Loaded"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <conv:BoolToVisibilityConverter         x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter  x:Key="InvBoolToVis"/>
        <conv:EmptyStringToVisibilityConverter  x:Key="StrToVis"/>
    </Window.Resources>

    <StackPanel Margin="28,24">

        <!-- Title -->
        <TextBlock Text="{Binding DialogTitle}"
                   FontSize="20" FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <!-- Username -->
        <TextBox x:Name="TxtUsername"
                 materialDesign:HintAssist.Hint="Usuário *"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                 Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,0,0,12"/>

        <!-- Full name -->
        <TextBox materialDesign:HintAssist.Hint="Nome Completo *"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                 Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,0,0,12"/>

        <!-- Role -->
        <ComboBox materialDesign:HintAssist.Hint="Perfil"
                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                  ItemsSource="{Binding Roles}"
                  SelectedItem="{Binding Role}"
                  Margin="0,0,0,12"/>

        <!-- Password -->
        <PasswordBox x:Name="PwdPassword"
                     materialDesign:HintAssist.Hint="Senha *"
                     Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                     PasswordChanged="PwdPassword_Changed"
                     Margin="0,0,0,8"/>

        <!-- Confirm password — shown for new users OR when password is being changed -->
        <PasswordBox x:Name="PwdConfirm"
                     materialDesign:HintAssist.Hint="Confirmar Senha *"
                     Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                     PasswordChanged="PwdConfirm_Changed"
                     Margin="0,0,0,4"/>
        <TextBlock Text="(deixe em branco para não alterar a senha)"
                   FontSize="11" Opacity="0.55" Margin="0,0,0,8"
                   Visibility="{Binding IsNewUser, Converter={StaticResource InvBoolToVis}}"/>

        <!-- Error -->
        <Border Background="#FFFFE0E0" CornerRadius="4" Padding="10,6"
                Margin="0,0,0,8"
                Visibility="{Binding ErrorMessage, Converter={StaticResource StrToVis}}">
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="#FFC62828"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Cancelar"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Command="{Binding CancelCommand}"
                    Margin="0,0,10,0" Width="100"/>
            <Button Content="Salvar"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Command="{Binding SaveCommand}"
                    IsDefault="True" Width="100"/>
        </StackPanel>

    </StackPanel>
</Window>
