<UserControl x:Class="PDV.WPF.Views.StockView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:conv="clr-namespace:PDV.WPF.Converters">
    <UserControl.Resources>
        <conv:CurrencyConverter x:Key="Currency"/>
    </UserControl.Resources>
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <TabControl Grid.Column="0" Margin="0,0,8,0">
            <TabItem Header="Produtos com Estoque Baixo">
                <DataGrid ItemsSource="{Binding LowStockProducts}" AutoGenerateColumns="False"
                          CanUserAddRows="False" Style="{StaticResource MaterialDesignDataGrid}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Produto" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Categoria" Binding="{Binding CategoryName}" Width="120"/>
                        <DataGridTextColumn Header="Estoque" Binding="{Binding StockQuantity, StringFormat=N2}" Width="80"/>
                        <DataGridTextColumn Header="Mínimo" Binding="{Binding MinStockQuantity, StringFormat=N2}" Width="80"/>
                        <DataGridTextColumn Header="Un." Binding="{Binding UnitOfMeasure}" Width="60"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Últimas Movimentações">
                <DataGrid ItemsSource="{Binding Movements}" AutoGenerateColumns="False"
                          CanUserAddRows="False" Style="{StaticResource MaterialDesignDataGrid}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Produto" Binding="{Binding ProductName}" Width="*"/>
                        <DataGridTextColumn Header="Tipo" Binding="{Binding Type}" Width="80"/>
                        <DataGridTextColumn Header="Qtd" Binding="{Binding Quantity, StringFormat=N2}" Width="70"/>
                        <DataGridTextColumn Header="Anterior" Binding="{Binding PreviousQuantity, StringFormat=N2}" Width="80"/>
                        <DataGridTextColumn Header="Novo" Binding="{Binding NewQuantity, StringFormat=N2}" Width="70"/>
                        <DataGridTextColumn Header="Motivo" Binding="{Binding Reason}" Width="140"/>
                        <DataGridTextColumn Header="Data" Binding="{Binding CreatedAt, StringFormat=dd/MM/yy HH:mm}" Width="110"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>

        <materialDesign:Card Grid.Column="1" Padding="16">
            <StackPanel>
                <TextBlock Text="Ajuste de Estoque" FontSize="16" FontWeight="Bold" Margin="0,0,0,16"/>
                <ComboBox materialDesign:HintAssist.Hint="Produto"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          ItemsSource="{Binding AllProducts}"
                          DisplayMemberPath="Name"
                          SelectedItem="{Binding SelectedProduct}"
                          Margin="0,6"/>
                <ComboBox materialDesign:HintAssist.Hint="Tipo"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          ItemsSource="{Binding MovementTypes}"
                          SelectedItem="{Binding AdjustType}"
                          Margin="0,6"/>
                <TextBox materialDesign:HintAssist.Hint="Quantidade"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding AdjustQuantity}" Margin="0,6"/>
                <TextBox materialDesign:HintAssist.Hint="Motivo"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding AdjustReason}" Margin="0,6"/>
                <TextBlock Text="{Binding StatusMessage}" Foreground="Green" Margin="0,4" TextWrapping="Wrap"/>
                <Button Content="Aplicar Ajuste" Style="{StaticResource MaterialDesignRaisedButton}"
                        Command="{Binding AdjustStockCommand}" Margin="0,8"/>
                <Button Content="Atualizar" Style="{StaticResource MaterialDesignOutlinedButton}"
                        Command="{Binding LoadCommand}" Margin="0,4"/>
            </StackPanel>
        </materialDesign:Card>
    </Grid>
</UserControl>
