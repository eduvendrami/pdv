<UserControl x:Class="PDV.WPF.Views.SaleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:conv="clr-namespace:PDV.WPF.Converters"
             Loaded="UserControl_Loaded">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:CurrencyConverter x:Key="Currency"/>
        <conv:NullToVisibilityConverter x:Key="NullToVis"/>
        <conv:EmptyStringToVisibilityConverter x:Key="StrToVis"/>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ LEFT: Busca + Carrinho ═══ -->
        <DockPanel Grid.Column="0" Margin="0,0,12,0">

            <!-- Campo único de busca -->
            <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtSearch"
                         materialDesign:HintAssist.Hint="Cód. barras / nome / 5*cimento  (Enter busca)"
                         materialDesign:TextFieldAssist.HasClearButton="True"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         FontSize="15"
                         Text="{Binding SearchInput, UpdateSourceTrigger=PropertyChanged}"
                         KeyDown="TxtSearch_KeyDown"/>
                <Button Grid.Column="1" Content="Buscar"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Command="{Binding SearchCommand}"
                        Margin="8,0,0,0" Height="40"/>
            </Grid>

            <!-- Painel de resultados múltiplos -->
            <Border DockPanel.Dock="Top"
                    Visibility="{Binding ShowSearchResults, Converter={StaticResource BoolToVis}}"
                    BorderBrush="{DynamicResource MaterialDesign.Brush.Primary}"
                    BorderThickness="1,1,1,2" CornerRadius="4"
                    Margin="0,0,0,6" MaxHeight="220"
                    Background="{DynamicResource MaterialDesign.Brush.Card.Background}">
                <DockPanel>
                    <Border DockPanel.Dock="Top"
                            Background="{DynamicResource MaterialDesign.Brush.Primary}"
                            Padding="10,6">
                        <DockPanel>
                            <TextBlock Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center">
                                <Run Text="{Binding SearchResults.Count, Mode=OneWay}"/>
                                <Run Text=" produtos encontrados — ↑↓ navegar, Enter adicionar"/>
                            </TextBlock>
                            <Button DockPanel.Dock="Right"
                                    Style="{StaticResource MaterialDesignIconButton}"
                                    Foreground="White"
                                    Command="{Binding ClearSearchResultsCommand}"
                                    ToolTip="Fechar (Esc)"
                                    Width="28" Height="28">
                                <materialDesign:PackIcon Kind="Close" Width="14" Height="14"/>
                            </Button>
                        </DockPanel>
                    </Border>

                    <ListBox x:Name="LstResults"
                             ItemsSource="{Binding SearchResults}"
                             SelectedIndex="{Binding SelectedResultIndex}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             PreviewMouseDown="LstResults_PreviewMouseDown"
                             MouseDoubleClick="LstResults_MouseDoubleClick"
                             KeyDown="LstResults_KeyDown"
                             BorderThickness="0">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource MaterialDesignListBoxItem}">
                                <Setter Property="Padding" Value="10,8"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Barcode}"
                                               Opacity="0.6" Margin="12,0" VerticalAlignment="Center" MinWidth="110"/>
                                    <TextBlock Grid.Column="2" Opacity="0.6" Margin="0,0,12,0" VerticalAlignment="Center">
                                        <Run Text="Estoque: "/>
                                        <Run Text="{Binding StockQuantity, StringFormat=N2}"/>
                                    </TextBlock>
                                    <TextBlock Grid.Column="3"
                                               Text="{Binding SalePrice, Converter={StaticResource Currency}}"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Status -->
            <TextBlock DockPanel.Dock="Top"
                       Text="{Binding StatusMsg}"
                       Foreground="{DynamicResource MaterialDesign.Brush.Secondary}"
                       Margin="2,0,0,4" FontSize="12"
                       Visibility="{Binding StatusMsg, Converter={StaticResource StrToVis}}"/>

            <!-- Carrinho -->
            <DataGrid x:Name="GridItems"
                      ItemsSource="{Binding Items}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      Style="{StaticResource MaterialDesignDataGrid}"
                      KeyDown="GridItems_KeyDown">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Produto" Binding="{Binding ProductName}" Width="*" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Cód. Barras" Binding="{Binding Barcode}" Width="110" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Qtd"
                                        Binding="{Binding Quantity, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}"
                                        Width="70"/>
                    <DataGridTextColumn Header="Preço Un."
                                        Binding="{Binding UnitPrice, StringFormat=C2, UpdateSourceTrigger=PropertyChanged}"
                                        Width="90"/>
                    <DataGridTextColumn Header="Desc."
                                        Binding="{Binding DiscountAmount, StringFormat=C2, UpdateSourceTrigger=PropertyChanged}"
                                        Width="80"/>
                    <DataGridTextColumn Header="Total" Binding="{Binding TotalPrice, StringFormat=C2}" Width="90" IsReadOnly="True"/>
                    <DataGridTemplateColumn Width="42" IsReadOnly="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource MaterialDesignIconButton}"
                                        Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="Remover (Del)"
                                        Width="32" Height="32">
                                    <materialDesign:PackIcon Kind="Delete" Width="16" Height="16"/>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <!-- ═══ RIGHT: Resumo + Ações ═══ -->
        <materialDesign:Card Grid.Column="1" Padding="16">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="Resumo da Venda"
                           FontSize="16" FontWeight="Bold"
                           Margin="0,0,0,16"/>

                <TextBox DockPanel.Dock="Top"
                         materialDesign:HintAssist.Hint="Cliente (opcional)"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding SelectedCustomer.Name, Mode=OneWay}"
                         IsReadOnly="True" Margin="0,0,0,10"/>

                <TextBox DockPanel.Dock="Top"
                         materialDesign:HintAssist.Hint="Desconto geral (R$)"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding DiscountAmount, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding CanApplyDiscount}"
                         Visibility="{Binding CanApplyDiscount, Converter={StaticResource BoolToVis}}"
                         Margin="0,0,0,10"/>

                <TextBox DockPanel.Dock="Top"
                         materialDesign:HintAssist.Hint="Observações"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding Notes}"
                         Margin="0,0,0,10"/>

                <Separator DockPanel.Dock="Top" Margin="0,4,0,12"/>

                <Grid DockPanel.Dock="Top" Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Subtotal:" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding Subtotal, Converter={StaticResource Currency}}"
                               FontWeight="SemiBold"/>
                </Grid>

                <Grid DockPanel.Dock="Top" Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="TOTAL:" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding Total, Converter={StaticResource Currency}}"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
                </Grid>

                <Separator DockPanel.Dock="Top" Margin="0,12,0,16"/>

                <StackPanel DockPanel.Dock="Bottom">
                    <Button x:Name="BtnFinalize"
                            Content="✓  FINALIZAR  (F9)"
                            FontSize="15" Height="52"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Command="{Binding FinalizeSaleCommand}"
                            Margin="0,0,0,8"/>
                    <Button Content="✗  CANCELAR VENDA  (F4)"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Command="{Binding ClearSaleCommand}"
                            Height="40"/>
                    <TextBlock Text="{Binding StatusMsg}"
                               Foreground="Green"
                               Margin="0,10,0,0"
                               TextWrapping="Wrap"
                               FontSize="12"/>
                </StackPanel>

                <Grid/>
            </DockPanel>
        </materialDesign:Card>
    </Grid>
</UserControl>
