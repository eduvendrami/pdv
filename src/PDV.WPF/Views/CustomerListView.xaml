<UserControl x:Class="PDV.WPF.Views.CustomerListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBox materialDesign:HintAssist.Hint="Buscar cliente..."
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Width="300" Text="{Binding SearchTerm, UpdateSourceTrigger=PropertyChanged}"/>
            <Button Content="Buscar" Margin="8,0" Command="{Binding LoadCommand}"/>
            <Button Content="Novo Cliente" Style="{StaticResource MaterialDesignRaisedButton}"
                    Command="{Binding NewCustomerCommand}" Margin="8,0"/>
        </StackPanel>
        <DataGrid ItemsSource="{Binding Customers}" AutoGenerateColumns="False"
                  CanUserAddRows="False" Style="{StaticResource MaterialDesignDataGrid}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Nome" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="CPF/CNPJ" Binding="{Binding CpfCnpj}" Width="130"/>
                <DataGridTextColumn Header="Telefone" Binding="{Binding Phone}" Width="120"/>
                <DataGridTextColumn Header="Cidade" Binding="{Binding City}" Width="100"/>
                <DataGridTextColumn Header="Limite" Binding="{Binding CreditLimit, StringFormat=C2}" Width="90"/>
                <DataGridTemplateColumn Width="90">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource MaterialDesignIconButton}"
                                        Command="{Binding DataContext.EditCustomerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}">
                                    <materialDesign:PackIcon Kind="Pencil"/>
                                </Button>
                                <Button Style="{StaticResource MaterialDesignIconButton}"
                                        Command="{Binding DataContext.DeleteCustomerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}" Foreground="Red">
                                    <materialDesign:PackIcon Kind="Delete"/>
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
